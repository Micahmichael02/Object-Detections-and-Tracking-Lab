# Secrets / credentials — never commit real keys
.env
*.env
serviceAccountKey.json
*serviceAccountKey*.json
**/credentials.json
*.pem
*.key

# Python
__pycache__/
*.pyc
.venv/
venv/

# Editors
.idea/
.vscode/

# Large media (videos) — too big for GitHub
*.mp4
*.avi
*.mov
*.mkv

# Model weights / checkpoints
*.pt
*.pth
*.onnx
*.weights
*.h5
*.hdf5
*.tflite

# Datasets / large data dumps
*.zip
*.pkl
sign_lan_detections/data/
sign_lan_detections/mydataset/
